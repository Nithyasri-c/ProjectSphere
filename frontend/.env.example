# Frontend Configuration Example for Render
# This file uses Vite environment variables (VITE_ prefix)

# API URL - points to backend
# For local development:
VITE_API_URL=http://localhost:5000/api

# For Render production (replace with your actual Render backend URL):
# VITE_API_URL=https://your-app-backend.onrender.com/api

# Application URL
# For local development:
VITE_APP_URL=http://localhost:5173

# For Render production:
# VITE_APP_URL=https://your-app-frontend.onrender.com
